# Meridian Legal LLP — Environment Variables
# Stack: Microsoft SQL Server 2022 + Redis 7
# Copy to .env and fill in. Never commit .env to git.

# SQL Server SA password (must be >= 8 chars, upper+lower+digit+symbol)
SA_PASSWORD=Change_Me_Strong!Password123

# Internal Redis (port 6380)
REDIS_PASSWORD=change_me_redis_password_here

# PACT Platform connection (the governance gateway)
PACT_GATEWAY_ENDPOINT=https://localhost:50051
PACT_API_ENDPOINT=https://localhost:8080

# Auto-populated by bootstrap_meridian.sh — do not edit manually
MERIDIAN_TENANT_ID=
MERIDIAN_AGENT_ID=
MERIDIAN_POLICY_ID=
MERIDIAN_POLICY_HASH=
HARVEY_CERT_FINGERPRINT=
