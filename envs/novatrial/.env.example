# NovaTrial CRO — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Internal Postgres (novatrial_db on port 5434)
POSTGRES_PASSWORD=change_me_strong_password_here

# Internal Redis (port 6381)
REDIS_PASSWORD=change_me_redis_password_here

# PACT Platform connection (the governance gateway)
PACT_GATEWAY_ENDPOINT=https://localhost:50051
PACT_API_ENDPOINT=https://localhost:8080

# Auto-populated by bootstrap_novatrial.sh — do not edit manually
NOVATRIAL_TENANT_ID=
NOVATRIAL_AGENT_ID=
NOVATRIAL_POLICY_HASH=
ATLAS_CERT_FINGERPRINT=
